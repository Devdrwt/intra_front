{
  "name": "drwindesk",
  "version": "0.1.0",
  "private": true,
  "description": "DrwinDesk — intranet/ERP/SIRH (monorepo front)",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@drwindesk/web",
    "dev:app": "npm run dev --workspace=@drwindesk/app",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace=@drwindesk/web",
    "build:app": "npm run build --workspace=@drwindesk/app",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
