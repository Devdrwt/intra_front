# ── SPA interne DrwinDesk — .env de PRODUCTION (à recopier en `.env` sur le VPS) ──
# Sert UNIQUEMENT au runtime du conteneur (l'URL d'API est inlinée au build par la CI).

# Image GHCR (la CI met à jour `latest` à chaque push sur main touchant apps/app)
APP_IMAGE=ghcr.io/devdrwt/intra_front:latest
# Fait que `docker compose` utilise le fichier de prod par défaut
COMPOSE_FILE=docker-compose.app.prod.yml
# Port loopback UNIQUE sur le VPS — nginx proxie app.drwintech.com -> ce port
# (api = 3100, app = 3200)
HOST_PORT=3200
