# --- API ---
# Laisser vide en dev : le client utilise /api/v1 via le proxy Vite (cookies same-origin).
VITE_API_URL=
# Cible du proxy /api en dev (backend NestJS intra_back)
VITE_API_PROXY=http://localhost:3000

# --- Mocks (front sans backend complet) ---
# auth : RÉEL par défaut. Mettre 'true' pour bosser totalement hors-ligne.
VITE_MOCK_AUTH=
# Modules métier : mockés par défaut (jouables sans DB).
# Global : 'false' bascule tout en réel. Chaque override par domaine est prioritaire.
VITE_USE_MOCKS=true
# RH est implémenté côté backend : mettre 'false' quand backend + PostgreSQL tournent
# (migration + seed faits) pour consommer les vrais /api/v1/employes.
VITE_MOCK_RH=
VITE_MOCK_PRESENCES=
VITE_MOCK_DOCUMENTS=

# Upload de fichiers via presign S3 (off tant que le backend n'expose pas …/presign)
VITE_UPLOADS_ENABLED=false
