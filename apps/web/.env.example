# URL de l'app interne (SPA) vers laquelle pointe "Espace collaborateur"
NEXT_PUBLIC_APP_URL=http://localhost:3002
# Backend NestJS pour le proxy /api (rewrites Next, same-origin → cookies/CSRF sans CORS).
