# URL de l'app interne (SPA) vers laquelle pointe "Espace collaborateur"
NEXT_PUBLIC_APP_URL=http://localhost:3002
# Backend NestJS pour le proxy /api (rewrites Next, same-origin → cookies/CSRF sans CORS).
# Variable SERVEUR (pas NEXT_PUBLIC). Défaut: http://localhost:3000
BACKEND_URL=http://localhost:3000

# Upload CV via presign S3 (off tant que le backend n'expose pas …/presign)
NEXT_PUBLIC_UPLOADS_ENABLED=false
